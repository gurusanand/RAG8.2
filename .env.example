# ============================================
# Banking RAG Application — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load before running:
#   Windows CMD:    for /f "tokens=1,2 delims==" %a in (.env) do set %a=%b
#   Windows PS:     Get-Content .env | ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) }
#   macOS/Linux:    export $(cat .env | xargs)

# Required: OpenAI API Key (for LLM calls and embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom MongoDB connection string (default: mongodb://localhost:27017)
MONGODB_URI=mongodb://localhost:27017

# ── Langfuse Observability (optional — set to enable tracing) ──
# Self-hosted: docker compose -f docker-compose-langfuse.yml up -d
# Cloud: sign up at https://cloud.langfuse.com
# Works with Langfuse SDK v2.x, v3.x, and v4.x (auto-detected)
# Use LANGFUSE_HOST for v2/v3, LANGFUSE_BASE_URL for v4 (both are read)
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_BASE_URL=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
