# ============================================================
# 7-Layer Advanced RAG — Banking Assistant
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# ============================================================

# OpenAI API Key (Required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk- 

# OpenAI Base URL (Optional — only change if using a proxy or compatible API)
# Default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1


LANGFUSE_HOST=http://localhost:3100
LANGFUSE_BASE_URL=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-
LANGFUSE_SECRET_KEY=sk-6
# ── Feature Toggle ──
LANGFUSE_ENABLED=true                        # Master toggle (true/false)

# ── Docker Compose Port Configuration ──
LANGFUSE_PORT=3100                           # Port for Langfuse UI (default: 3100)
LANGFUSE_DB_PORT=5433                        # Port for PostgreSQL (default: 5433)

# ── Security (Change these in production!) ──
LANGFUSE_NEXTAUTH_SECRET=change-me-to-a-random-string
LANGFUSE_SALT=change-me-to-a-different-random-string

# ── Optional ──
LANGFUSE_TELEMETRY=true                      # Send anonymous usage stats to Langfuse
LANGFUSE_EXPERIMENTAL=false                  # Enable experimental features


# Optional: Custom MongoDB connection string (default: mongodb://localhost:27017)
MONGODB_URI=mongodb://localhost:27017